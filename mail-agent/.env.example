# ===========================================
# PANDORA Mail Agent - Configuración
# ===========================================

# Método de conexión: "powerautomate" | "smtp" | "graph" | "imap_oauth" | "imap_basic"
# - powerautomate: Lee JSON de Power Automate + envía via SMTP (RECOMENDADO)
# - smtp: Solo envío de correos (lectura no disponible)
# - graph: Microsoft Graph API (requiere admin consent)
# - imap_oauth/imap_basic: IMAP (probablemente bloqueado en M365)
CONNECTION_METHOD=powerautomate

# --- SMTP (Probado y funcional con M365) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_EMAIL=tu.correo@entidad.gov.co
SMTP_PASSWORD=tu-contraseña

# --- Power Automate ---
# Carpeta donde Power Automate guarda los JSON exportados
# Por defecto: ~/Library/CloudStorage/OneDrive-Personal/MailExport
POWERAUTOMATE_EXPORT_FOLDER=/ruta/a/OneDrive/MailExport

# --- General ---
USER_EMAIL=tu.correo@entidad.gov.co

# --- Bot de respuesta automática ---
AUTO_RESPOND=false
AUTO_RESPOND_CATEGORIES=password_reset,user_data_request

# --- Microsoft Graph API (si admin consent disponible) ---
# AZURE_CLIENT_ID=tu-client-id
# AZURE_TENANT_ID=tu-tenant-id
# GRAPH_SCOPES=Mail.Read,Mail.Send

# --- IMAP (probablemente bloqueado) ---
# IMAP_SERVER=outlook.office365.com
# IMAP_PORT=993
# IMAP_EMAIL=tu.correo@entidad.gov.co
# IMAP_PASSWORD=tu-contraseña

# --- Anthropic API (Opcional, para clasificación inteligente) ---
# ANTHROPIC_API_KEY=sk-ant-...
