# ============================================================
# AUTOMATINFORMES - Variables de entorno
# ============================================================
# Copiar este archivo como .env y completar con valores reales
# cp .env.example .env
# ============================================================

# --- Fase 1: Jira Cloud (IDARTES) ---
JIRA_IDARTES_URL=https://idartes-tecnologia.atlassian.net
JIRA_IDARTES_EMAIL=
JIRA_IDARTES_API_TOKEN=

# --- Fase 2: Gmail (IDT, IDARTES) ---
# Las credenciales OAuth se almacenan en ~/.gmail-mcp/
# Ver README de @gongrzhe/server-gmail-autoauth-mcp
# GMAIL_OAUTH_KEYS_PATH=~/.gmail-mcp/gcp-oauth.keys.json
# GMAIL_IDT_CREDENTIALS_PATH=~/.gmail-mcp/idt-credentials.json
# GMAIL_IDARTES_CREDENTIALS_PATH=~/.gmail-mcp/idartes-credentials.json

# --- Fase 3: GLPI API (IDARTES, SDMUJER) ---
GLPI_IDARTES_URL=https://soporteti.idartes.gov.co/apirest.php
GLPI_IDARTES_APP_TOKEN=
GLPI_IDARTES_USER_TOKEN=

GLPI_SDMUJER_URL=https://mesadeayuda.sdmujer.gov.co/glpi/apirest.php
GLPI_SDMUJER_APP_TOKEN=
GLPI_SDMUJER_USER_TOKEN=

# --- Fase 4: Outlook / Microsoft 365 (SDMUJER, UAECD) ---
SDMUJER_TENANT_ID=
SDMUJER_CLIENT_ID=
SDMUJER_CLIENT_SECRET=

UAECD_TENANT_ID=
UAECD_CLIENT_ID=
UAECD_CLIENT_SECRET=
